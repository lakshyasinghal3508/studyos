# StudyOS Frontend — copy to .env.local
# =============================================

# Backend API
VITE_API_URL=http://localhost:4000/api

# Gemini AI (free) — get from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaSy-your-key-here

# Firebase Phone Auth — get from https://console.firebase.google.com
# Project Settings → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=AIzaSy-your-firebase-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
