# StudyOS Frontend — copy to .env.local
# Backend API URL
VITE_API_URL=http://localhost:4000/api

# Gemini API Key (free) — get from https://aistudio.google.com/apikey
# Used as fallback if backend AI is unavailable
VITE_GEMINI_API_KEY=AIzaSy-your-key-here

# For Vercel production:
# VITE_API_URL=https://studyos-backend-xxxx.onrender.com/api
# VITE_GEMINI_API_KEY=AIzaSy-your-actual-key
